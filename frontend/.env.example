# Copy to .env and adjust.

# Backend API base URL
VITE_API_URL=http://localhost:8000

# (Optional) Google OAuth — create an OAuth 2.0 Client ID (type: Web application)
# at https://console.cloud.google.com/apis/credentials and add
# http://localhost:5173 to "Authorized JavaScript origins".
# Leave blank to use the built-in "Continue with Google (demo)" fallback.
VITE_GOOGLE_CLIENT_ID=
